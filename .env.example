# Copy to .env.local for local dev. In Vercel, set these as Environment Variables.

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# === Resend (email) ===
RESEND_API_KEY=re_...your-resend-api-key
RESEND_FROM_EMAIL=onboarding@resend.dev
# For production replace with: no-reply@yourdomain.com (verified in Resend)

# === App ===
APP_URL=http://localhost:3000
# In Vercel set this to your production URL e.g. https://pr-system.vercel.app

DEFAULT_ADMIN_EMAIL=shubhamjadhav.code@gmail.com
